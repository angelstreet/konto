# ═══════════════════════════════════════════════════════════
# Konto — Environment Variables
# Copy to backend/.env and fill in your values
# ═══════════════════════════════════════════════════════════

# App URL (used for OAuth callbacks)
APP_URL=http://localhost:3003

# Database (SQLite local or Turso cloud)
DATABASE_URL=file:./db/konto.db
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=

# Database Encryption (AES-256-GCM for sensitive columns)
# Generate with: openssl rand -hex 32
DB_ENCRYPTION_KEY=

# Auth (Clerk — optional, disabled if empty)
# CLERK_SECRET_KEY=
# VITE_CLERK_PUBLISHABLE_KEY=

# Legacy admin (used when Clerk is disabled)
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_NAME=Admin

# Powens Banking API (optional — for bank sync)
# Register at https://powens.com
POWENS_CLIENT_ID=
POWENS_CLIENT_SECRET=
POWENS_DOMAIN=your-domain.biapi.pro
POWENS_REDIRECT_URI=${APP_URL}/api/bank-callback

# Coinbase (optional — for crypto portfolio)
COINBASE_CLIENT_ID=
COINBASE_CLIENT_SECRET=
COINBASE_REDIRECT_URI=${APP_URL}/api/coinbase-callback

# Google Drive (optional — for document import)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_DRIVE_REDIRECT_URI=${APP_URL}/api/drive-callback

# Smoobu (optional — for property management)
SMOOBU_API_KEY=

# Pappers (optional — for French company lookup)
PAPPERS_API_TOKEN=

# API Security Token (protects admin endpoints)
API_TOKEN=change-me
