{
  "framework": "vite",
  "installCommand": "npm install",
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/konto/manifest.webmanifest", "destination": "/manifest.webmanifest" },
    { "source": "/konto/sw.js", "destination": "/sw.js" },
    { "source": "/konto/registerSW.js", "destination": "/registerSW.js" },
    { "source": "/konto/workbox-:path*", "destination": "/workbox-:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
